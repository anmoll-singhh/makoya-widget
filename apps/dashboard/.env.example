# ── Dashboard env ───────────────────────────────────────────────
# Leave DB_MODE unset (or =mock) to run with in-memory demo data, zero setup.

# DB_MODE=supabase                     # switch to real database
# SUPABASE_URL=                        # supabase.com → Project → Settings → API
# SUPABASE_SERVICE_ROLE_KEY=           # same page (server-only, NEVER ship to browser)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=       # same page (browser-safe)

# NEXT_PUBLIC_CDN_BASE=https://cdn.makoya.example   # where loader.js/core.js are hosted

# STRIPE_SECRET_KEY=                   # dashboard.stripe.com → Developers → API keys
# STRIPE_WEBHOOK_SECRET=               # Developers → Webhooks
# RESEND_API_KEY=                      # resend.com → API Keys (scan report + follow-up emails)
