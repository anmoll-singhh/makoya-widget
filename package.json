{
  "name": "makoya",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/web"
  ],
  "scripts": {
    "build:widget": "npm run build -w @makoya/widget",
    "build:widget:deploy": "npm run build:widget && node scripts/copy-widget-bundles.mjs",
    "sync:shared": "node scripts/sync-shared.mjs",
    "typecheck": "npm run typecheck -w @makoya/web && npm run typecheck -w @makoya/widget",
    "test": "npm run test -w @makoya/web",
    "test:widget": "npm run test -w @makoya/widget",
    "ci": "npm run sync:shared && npm run typecheck && npm run test && npm run test:widget"
  },
  "devDependencies": {
    "jsdom": "^29.1.1"
  }
}
